<launch> 
    <!-- 启动机器人的控制节点 -->
    <node pkg="sebot_robot" type="sebot_controller" name="sebot_controller" respawn="true">
        <!-- 是否发布传感器话题 value：true发布 false不发布 -->
        <param name="ultraEnale"   type="bool" value="false"/>      <!-- 超声波使能 -->
        <param name="odomEnable"    type="bool" value="false"/>     <!-- 里程计使能 -->
        <param name="imuEnable"     type="bool" value="false"/>     <!-- imu使能 -->
    </node>

    <!-- 启动键盘控制结点 -->
    <node pkg="sebot_robot" type="sebot_keyboard"   name="sebot_keyboard" respawn="true"/>
</launch> 